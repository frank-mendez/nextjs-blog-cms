    "url": "git+https://github.com/frank-mendez/nextjs-blog-cms.git"
  },
  "license": "MIT",
  "author": "Frank Mendez",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "prepare": "husky"
