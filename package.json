{
  "name": "nextjs-blog-cms",
  "version": "1.0.0",
  "description": "A modern blog CMS built with Next.js, Supabase, and TailwindCSS",
  "keywords": [
    "cms",
    "nextjs",
    "supabase",
    "tailwindcss",
    "blog"
  ],
  "homepage": "https://github.com/frank-mendez/nextjs-blog-cms#readme",
  "bugs": {
    "url": "https://github.com/frank-mendez/nextjs-blog-cms/issues"
